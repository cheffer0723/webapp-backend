NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=https://obsidianabyss.com,https://www.obsidianabyss.com,http://127.0.0.1:8000,http://localhost:8000
ADMIN_TOKEN=
DATABASE_URL=

# Mail
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@obsidianabyss.com
SMTP_PASS=
MAIL_FROM=contact@obsidianabyss.com
MAIL_TO=contact@obsidianabyss.com

# Advisor
ANTHROPIC_API_KEY=
ADVISOR_MODEL=
ADVISOR_MODEL_BACKUP=

# Billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=https://www.obsidianabyss.com/access.html?checkout=success
BILLING_CANCEL_URL=https://www.obsidianabyss.com/access.html?checkout=cancelled

# Closed beta
BETA_APP_URL=https://www.obsidianabyss.com/beta.html
BETA_SESSION_COOKIE_NAME=obsidian_beta_session
BETA_INVITE_HOURS=168
BETA_SESSION_HOURS=336

# x402 agentic access (gates only GET /api/machine/backtesting)
# Set X402_ENABLED=true to turn the paid agent route on. Leave false and the route is free.
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_RECEIVING_ADDRESS=0xD0c7ac431D98e47230EF86E3391128D3aD0C6b13
X402_CURRENCY=USDC
X402_AMOUNT=$0.01
X402_BUILDER_CODE=
# Must be THIS backend's public base URL (used as the x402 resource URL).
PUBLIC_API_URL=https://webapp-backend-production-7f0f.up.railway.app

# Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532
BASE_SEPOLIA_WALLET_ADDRESS=0xD0c7ac431D98e47230EF86E3391128D3aD0C6b13
BASE_SEPOLIA_EXPLORER_URL=https://sepolia-explorer.base.org

# MiroFish
MIROFISH_BASE_URL=
MARKOV_ENGINE_OUTPUT_DIR=

# Smoke tests
API_BASE=https://obsidianabyss-api-production.up.railway.app
SMOKE_ORIGIN=https://obsidianabyss.com

